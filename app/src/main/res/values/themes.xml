<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base app theme used for the launch window (before Compose takes over). The in-app look is
      defined by CsmTheme in Compose; this only styles the initial window and status bar.
    -->
    <style name="Theme.CSM" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/csm_background</item>
        <item name="android:statusBarColor">@color/csm_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
